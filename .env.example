ANTHROPIC_API_KEY=your-anthropic-api-key-here
BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# Optional: Add a DATABASE_URL to enable persistent storage
# Without this, the app uses demo seed data that resets on refresh
# DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# Optional: Add a passcode to gate access to the app
# Without this, the app is open to anyone with the URL
# ACCESS_PASSCODE=your-secret-passcode
# COOKIE_MAX_AGE=86400          # seconds (86400 = 1 day, 31536000 = 1 year)
